          &lt;th style=&#34;text-align: left&#34;&gt;变化形式&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;供给量变动&lt;/td&gt;
