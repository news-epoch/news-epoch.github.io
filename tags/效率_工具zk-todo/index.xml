  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;TB(TD)&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;从上到下&lt;/td&gt;
      &lt;/tr&gt;
