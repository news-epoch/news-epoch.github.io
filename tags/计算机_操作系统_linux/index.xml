&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;
&lt;/div&gt;
&lt;/div&gt;&lt;/li&gt;
&lt;li&gt;&lt;code&gt;mv /boot/initramfs-$(uname -r).img /boot/initramfs-$(uname -r).img.bak&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;&lt;code&gt;mv /boot/initramfs-$(uname -r).img /boot/initramfs-$(uname -r).img.bak&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;&lt;code&gt;systemctl set-default multi-user.target 开机将默认进入文本界面&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;&lt;code&gt;reboot&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;chmod +x NVIDIA-Linux-x86_64-440.64.run&lt;/li&gt;
